<Window
    x:Class="LiveCaptionsTranslator.OcrQuickActionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OCR Quick Actions"
    Width="390"
    SizeToContent="Height"
    AllowsTransparency="True"
    Background="Transparent"
    KeyDown="Window_KeyDown"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None">

    <Border
        x:Name="CardRoot"
        Padding="14"
        Background="#EA1B1F24"
        CornerRadius="12"
        MouseLeftButtonDown="CardRoot_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="24"
                Direction="270"
                Opacity="0.38"
                ShadowDepth="8"
                Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="StatusText"
                Grid.Row="0"
                Foreground="#F4F7FA"
                FontSize="13"
                FontWeight="SemiBold"
                TextWrapping="Wrap" />

            <TextBlock
                x:Name="ReviewHintText"
                Grid.Row="1"
                Margin="0,5,0,0"
                Foreground="#FFD88B"
                FontSize="12"
                TextWrapping="Wrap"
                Visibility="Collapsed" />

            <Border
                Grid.Row="2"
                Margin="0,10,0,10"
                Padding="9"
                Background="#45111318"
                BorderBrush="#25FFFFFF"
                BorderThickness="1"
                CornerRadius="8">
                <ScrollViewer
                    MaxHeight="92"
                    VerticalScrollBarVisibility="Auto">
                    <TextBlock
                        x:Name="PreviewText"
                        FlowDirection="LeftToRight"
                        Foreground="#E8EDF2"
                        FontSize="12"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>

            <StackPanel
                x:Name="ResultPanel"
                Grid.Row="3"
                Margin="0,0,0,10"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="ResultTitleText"
                    Foreground="#F4F7FA"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap" />
                <ScrollViewer
                    Margin="0,5,0,0"
                    MaxHeight="155"
                    VerticalScrollBarVisibility="Auto">
                    <TextBlock
                        x:Name="ResultText"
                        Foreground="#E8EDF2"
                        FontSize="12"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </StackPanel>

            <WrapPanel
                x:Name="ActionButtonsPanel"
                Grid.Row="4"
                HorizontalAlignment="Left">
                <Button
                    x:Name="TranslateButton"
                    MinWidth="88"
                    Margin="0,0,7,7"
                    Click="TranslateButton_Click" />
                <Button
                    x:Name="SummarizeButton"
                    MinWidth="92"
                    Margin="0,0,7,7"
                    Click="SummarizeButton_Click" />
                <Button
                    x:Name="ClearBridgeButton"
                    MinWidth="154"
                    Margin="0,0,7,7"
                    FontWeight="SemiBold"
                    Click="ClearBridgeButton_Click" />
                <Button
                    x:Name="OpenFullReviewButton"
                    MinWidth="124"
                    Margin="0,0,7,7"
                    Click="OpenFullReviewButton_Click" />
                <Button
                    x:Name="RetryOcrButton"
                    MinWidth="88"
                    Margin="0,0,7,7"
                    Click="RetryOcrButton_Click" />
                <Button
                    x:Name="CloseButton"
                    MinWidth="72"
                    Margin="0,0,7,7"
                    Click="CloseButton_Click" />
            </WrapPanel>

            <WrapPanel
                x:Name="ResultButtonsPanel"
                Grid.Row="4"
                HorizontalAlignment="Left"
                Visibility="Collapsed">
                <Button
                    x:Name="CopyButton"
                    MinWidth="72"
                    Margin="0,0,7,7"
                    Click="CopyButton_Click" />
                <Button
                    x:Name="OpenFullResultButton"
                    MinWidth="118"
                    Margin="0,0,7,7"
                    Click="OpenFullResultButton_Click" />
                <Button
                    x:Name="BackButton"
                    MinWidth="72"
                    Margin="0,0,7,7"
                    Click="BackButton_Click" />
                <Button
                    x:Name="ResultCloseButton"
                    MinWidth="72"
                    Margin="0,0,7,7"
                    Click="CloseButton_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
