<Window
    x:Class="LiveCaptionsTranslator.RollingSummaryOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Rolling Summary"
    Width="390"
    Height="620"
    MinWidth="330"
    MinHeight="260"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="CanResizeWithGrip"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None"
    mc:Ignorable="d">

    <Border
        x:Name="OverlayRoot"
        Margin="6"
        Padding="10"
        Background="#E013151A"
        BorderBrush="#3FFFFFFF"
        BorderThickness="1"
        CornerRadius="10"
        MouseLeftButtonDown="OverlayRoot_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="ContentRow" Height="*" />
                <RowDefinition x:Name="FooterRow" Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ui:Button
                        x:Name="TopmostButton"
                        Width="30"
                        Height="28"
                        Margin="2,0,0,0"
                        Click="TopmostButton_Click"
                        Icon="{ui:SymbolIcon pin20}" />
                    <ui:Button
                        x:Name="CollapseButton"
                        Width="30"
                        Height="28"
                        Margin="2,0,0,0"
                        Click="CollapseButton_Click"
                        Icon="{ui:SymbolIcon chevronUp20}" />
                    <ui:Button
                        x:Name="CloseButton"
                        Width="30"
                        Height="28"
                        Margin="2,0,0,0"
                        Click="CloseButton_Click"
                        Icon="{ui:SymbolIcon dismiss20}" />
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        x:Name="TitleText"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="White"
                        TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="StatusText"
                        Margin="0,2,0,0"
                        FontSize="11"
                        Foreground="#C9FFFFFF"
                        TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>

            <WrapPanel
                x:Name="CommandPanel"
                Grid.Row="1"
                Margin="0,10,0,8"
                Orientation="Horizontal">
                <Button
                    x:Name="StartButton"
                    MinWidth="66"
                    Margin="0,0,6,6"
                    Click="StartButton_Click" />
                <Button
                    x:Name="PauseButton"
                    MinWidth="66"
                    Margin="0,0,6,6"
                    Click="PauseButton_Click" />
                <Button
                    x:Name="ResumeButton"
                    MinWidth="66"
                    Margin="0,0,6,6"
                    Click="ResumeButton_Click" />
                <Button
                    x:Name="ProcessNowButton"
                    MinWidth="104"
                    Margin="0,0,6,6"
                    Click="ProcessNowButton_Click" />
                <Button
                    x:Name="StopButton"
                    MinWidth="66"
                    Margin="0,0,6,6"
                    Click="StopButton_Click" />
            </WrapPanel>

            <ScrollViewer
                x:Name="BatchesScrollViewer"
                Grid.Row="2"
                VerticalScrollBarVisibility="Auto"
                PreviewMouseWheel="BatchesScrollViewer_PreviewMouseWheel">
                <ItemsControl x:Name="BatchesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="10"
                                Background="#1EFFFFFF"
                                BorderBrush="#26FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="{Binding Header}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,5,0,0"
                                        FontWeight="SemiBold"
                                        Foreground="#F2FFFFFF"
                                        Text="{Binding Topic}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        Foreground="#E6FFFFFF"
                                        Text="{Binding Summary}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontWeight="SemiBold"
                                        Foreground="#F2FFFFFF"
                                        Text="{Binding ActionsHeader}" />
                                    <TextBlock
                                        Foreground="#DFFFFFFF"
                                        Text="{Binding Actions}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontWeight="SemiBold"
                                        Foreground="#F2FFFFFF"
                                        Text="{Binding DatesHeader}" />
                                    <TextBlock
                                        Foreground="#DFFFFFFF"
                                        Text="{Binding Dates}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontWeight="SemiBold"
                                        Foreground="#F2FFFFFF"
                                        Text="{Binding WarningsHeader}" />
                                    <TextBlock
                                        Foreground="#DFFFFFFF"
                                        Text="{Binding Warnings}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontWeight="SemiBold"
                                        Foreground="#F2FFFFFF"
                                        Text="{Binding UnresolvedHeader}" />
                                    <TextBlock
                                        Foreground="#DFFFFFFF"
                                        Text="{Binding Unresolved}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock
                x:Name="EmptyText"
                Grid.Row="2"
                Margin="0,16,0,0"
                Foreground="#BFFFFFFF"
                TextWrapping="Wrap" />

            <WrapPanel
                x:Name="FooterPanel"
                Grid.Row="3"
                Margin="0,10,0,0"
                Orientation="Horizontal">
                <Button
                    x:Name="SaveButton"
                    MinWidth="150"
                    Margin="0,0,6,6"
                    Click="SaveButton_Click" />
                <Button
                    x:Name="ClearButton"
                    MinWidth="150"
                    Margin="0,0,6,6"
                    Click="ClearButton_Click" />
                <Button
                    x:Name="FullReviewButton"
                    MinWidth="128"
                    Margin="0,0,6,6"
                    Click="FullReviewButton_Click" />
            </WrapPanel>
        </Grid>
    </Border>
</Window>
